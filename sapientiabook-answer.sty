%% 通过设置一个布尔值来控制答案显示与否
%	 代码来源：https://ljguo1020.github.io/2022/11/11/LaTeX-show-answer/

\ProvidesClass{sapientiabook-answer}[2024/12/28 sapientiabook v0.0.1 class]

\NeedsTeXFormat{LaTeX2e}
\RequirePackage{expl3}
\RequirePackage{xcolor}


\ExplSyntaxOn

%%	定义两个变量
\tl_clear_new:N \__answer_tl % 用于保存答案
\bool_new:N \__answer_bool % bool变量，用于控制答案显示与否

%\bool_set_true:N \__answer_bool % 将 \__answer_bool 设置为真，则显示答案，如果注释掉，则不显示
%\iffalse
\keys_define:nn{answer}
  {
    show-answer.code:n = {\bool_set_true:N \__answer_bool}
  } % 使用 l3keys 包提供的键值设置，定义了一个 show-answer 键，他的内容是将 bool 变量设置为逻辑真

\ProcessKeysOptions{answer} % 如果加了show-answer可选项，则显示答案，反之则不显示
%\fi

%%	声明答案环境

\NewDocumentEnvironment{answer}{+b}
  {
    \tl_set:Nn \__answer_tl
    {
      \noindent\textbf{\textcolor{cyan}{答案：}}
      {\fangsong #1}
    }
  } % 这是将答案的内容写进 \__answer_tl 这个变量里面
  {
    \par 
    \bool_if:NT\__answer_bool{\tl_use:N   \__answer_tl}
  } % \bool_if:NT 函数用于判断 \__answer_bool 这个 bool 变量的真假，如果为真则执行
\ExplSyntaxOff
\endinput